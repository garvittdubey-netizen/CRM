    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/node": "^22.15.3",
    "prisma": "^5.22.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
