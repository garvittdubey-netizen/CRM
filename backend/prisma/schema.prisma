generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String          @id @default(cuid())
  name            String
  email           String          @unique
  password        String
  role            Role            @default(AGENT)
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  leads           Lead[]          @relation("AssignedAgent")
  followUps       FollowUp[]      @relation("FollowUpAgent")
  communications  Communication[] @relation("CommunicationCreator")
  activities      Activity[]      @relation("UserActivities")

  @@map("users")
}

model Lead {
  id                String     @id @default(cuid())
  fullName          String
  phone             String?
  email             String?
  budget            Decimal?   @db.Decimal(15, 2)
  preferredLocation String?
  bhk               String?
  propertyType      String?
  status            LeadStatus @default(NEW)
  source            LeadSource @default(MANUAL)
  tags              String[]
  notes             String?    @db.Text
  assignedAgentId   String?
  assignedAgent     User?      @relation("AssignedAgent", fields: [assignedAgentId], references: [id])
  followUps         FollowUp[] @relation("LeadFollowUps")
  communications    Communication[] @relation("LeadCommunications")
  activities        Activity[] @relation("LeadActivities")
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@map("leads")
}

model FollowUp {
  id              String         @id @default(cuid())
  leadId          String
  lead            Lead           @relation("LeadFollowUps", fields: [leadId], references: [id], onDelete: Cascade)
  assignedAgentId String
  assignedAgent   User           @relation("FollowUpAgent", fields: [assignedAgentId], references: [id])
  followUpDate    DateTime
  reminderDate    DateTime?
  status          FollowUpStatus @default(PENDING)
  notes           String?        @db.Text
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([assignedAgentId, followUpDate])
  @@index([leadId])
  @@index([status, followUpDate])
  @@map("follow_ups")
}

enum Role {
  ADMIN
  AGENT
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  NEGOTIATING
  WON
  LOST
}

enum FollowUpStatus {
  PENDING
  COMPLETED
  MISSED
}

enum LeadSource {
  FACEBOOK
  WHATSAPP
  WEBSITE
  REFERRAL
  MANUAL
  PROPERTY_PORTAL
  OTHER
}

model Communication {
  id                String                  @id @default(cuid())
  leadId            String
  lead              Lead                    @relation("LeadCommunications", fields: [leadId], references: [id], onDelete: Cascade)
  type              CommunicationType
  direction         CommunicationDirection?
  message           String?                 @db.Text
  templateName      String?
  templateLang      String?
  templateParams    Json?
  callDuration      Int?
  callOutcome       String?
  status            String                  @default("PENDING")
  whatsappMessageId String?                 @unique
  errorCode         Int?
  errorDetail       String?                 @db.Text
  createdById       String?
  createdBy         User?                   @relation("CommunicationCreator", fields: [createdById], references: [id])
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@index([leadId, createdAt])
  @@index([type, createdAt])
  @@map("communications")
}

model Activity {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("UserActivities", fields: [userId], references: [id])
  leadId      String?
  lead        Lead?    @relation("LeadActivities", fields: [leadId], references: [id], onDelete: SetNull)
  action      String
  description String   @db.Text
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([leadId, createdAt])
  @@map("activities")
}

enum CommunicationType {
  WHATSAPP
  CALL
}

enum CommunicationDirection {
  INBOUND
  OUTBOUND
}
