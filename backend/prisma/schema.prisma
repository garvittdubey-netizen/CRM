generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  password  String
  role      Role       @default(AGENT)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  leads     Lead[]     @relation("AssignedAgent")
  followUps FollowUp[] @relation("FollowUpAgent")

  @@map("users")
}

model Lead {
  id                String     @id @default(cuid())
  fullName          String
  phone             String?
  email             String?
  budget            Decimal?   @db.Decimal(15, 2)
  preferredLocation String?
  bhk               String?
  propertyType      String?
  status            LeadStatus @default(NEW)
  tags              String[]
  notes             String?    @db.Text
  assignedAgentId   String?
  assignedAgent     User?      @relation("AssignedAgent", fields: [assignedAgentId], references: [id])
  followUps         FollowUp[] @relation("LeadFollowUps")
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@map("leads")
}

model FollowUp {
  id              String         @id @default(cuid())
  leadId          String
  lead            Lead           @relation("LeadFollowUps", fields: [leadId], references: [id], onDelete: Cascade)
  assignedAgentId String
  assignedAgent   User           @relation("FollowUpAgent", fields: [assignedAgentId], references: [id])
  followUpDate    DateTime
  reminderDate    DateTime?
  status          FollowUpStatus @default(PENDING)
  notes           String?        @db.Text
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([assignedAgentId, followUpDate])
  @@index([leadId])
  @@index([status, followUpDate])
  @@map("follow_ups")
}

enum Role {
  ADMIN
  AGENT
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  NEGOTIATING
  WON
  LOST
}

enum FollowUpStatus {
  PENDING
  COMPLETED
  MISSED
}
